# Нусхабардорӣ ба .env.local. Сатрҳои зерро пур кунед.
#
# Neon: дар Dashboard ду URI гиред —
# 1) Pooled / pooled connection → DATABASE_URL (хост бо -pooler.)
# 2) Direct / non-pooling → DIRECT_URL (хост бе pooler, барои prisma migrate)
#
# Барои Prisma бо pooler ба URL чизи DATABASE_URL &pgbouncer=true илова кунед.
DATABASE_URL=postgresql://USER:PASSWORD@ep-PROJECT-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://USER:PASSWORD@ep-PROJECT.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15
#
# Агар Postgres нест, DATABASE_URL ва DIRECT_URL якхела бошанд ҳам мешавад.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=
